# Backend Environment Variables
# Copy this file to .env and fill in your values

# --- Database ---
# For local development (without Docker):
DATABASE_URL=postgresql://sms_user:sms_pass@localhost:5432/sms_db
# For Docker (already overridden by docker-compose.yml):
# DATABASE_URL=postgresql://sms_user:sms_pass@db:5432/sms_db

# --- JWT ---
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:80,http://localhost
